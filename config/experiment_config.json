{
  "experiment": "Circuit Structural Complexity Prediction",
  "version": "v4",
  "dataset": {
    "source": "data/all_circuits",
    "total_raw_circuits": 470,
    "dedup_max_variants": 3,
    "post_dedup_circuits": 284,
    "splits": {
      "method": "group-aware stratified",
      "test_size": 0.15,
      "val_size": 0.15,
      "seed": 42,
      "train": 204,
      "val": 39,
      "test": 41,
      "family_overlap": false
    },
    "target": "complexity_score",
    "target_stats": {
      "mean": 2.159,
      "std": 0.764,
      "range": [0.984, 4.774]
    }
  },
  "features": {
    "node_features": {
      "dim": 24,
      "description": "16-dim gate type one-hot + 8-dim local/global context"
    },
    "global_features": {
      "dim": 10,
      "normalization": "train-set z-score",
      "features": [
        "log10(gates+1) / 5.0",
        "depth / 50.0",
        "feedback_ratio",
        "seq_ratio",
        "scc_coverage",
        "xor_ratio",
        "reconvergent_ratio",
        "type_entropy / 4.0",
        "avg_fanout / 5.0",
        "edge_density / 3.0"
      ],
      "note": "Raw structural metrics only - no formula sub-terms. Ad-hoc pre-scaling (/5, /50, etc.) is further standardized via train-set z-score at load time."
    }
  },
  "model": {
    "architecture": "GIN+GAT dual-path with GlobalMLPBranch",
    "hidden_dim": 32,
    "gin_layers": 2,
    "gat_layers": 2,
    "gat_heads": 4,
    "dropout": 0.15,
    "global_dim": 10,
    "parameters": 16251
  },
  "training": {
    "epochs": 300,
    "batch_size": 32,
    "optimizer": "AdamW",
    "learning_rate": 0.0002,
    "weight_decay": 0.01,
    "loss": "HuberLoss (delta=1.0)",
    "scheduler": "ReduceLROnPlateau (factor=0.5, patience=15)",
    "early_stopping_patience": 40,
    "input_noise": 0.005,
    "gradient_clipping": 1.0,
    "target_normalization": "train-set z-score"
  },
  "results": {
    "gnn_combined": {
      "test_r2": 0.8397,
      "test_mae": 0.2224,
      "best_epoch": 82
    },
    "gnn_only": {
      "test_r2": 0.7404,
      "test_mae": 0.2661,
      "best_epoch": 59
    },
    "global_only": {
      "test_r2": 0.9364,
      "test_mae": 0.1303,
      "best_epoch": 175
    },
    "baselines": {
      "linear_regression_r2": 0.5510,
      "ridge_r2": 0.7088,
      "random_forest_r2": 0.8251,
      "gradient_boosting_r2": 0.9706
    }
  },
  "reproducibility": {
    "python": "3.11",
    "torch": "see requirements.txt",
    "torch_geometric": "see requirements.txt",
    "sklearn": "see requirements.txt",
    "random_seed": 42
  },
  "known_limitations": [
    "Only 3 sequential circuits in dataset (98.9% combinational)",
    "23.2x score bin imbalance ratio",
    "Only 24 circuits with 10K+ gates",
    "Target is a hand-tuned heuristic formula, not an external ground truth",
    "Naive concatenation fusion hurts: Combined (R2=0.84) < Global-only (R2=0.94)"
  ]
}
